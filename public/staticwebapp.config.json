{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/images/*",
      "/partners/*",
      "/*.{png,jpg,jpeg,gif,svg,ico,webp,avif}",
      "/*.{css,js,json,txt,xml,woff,woff2,ttf,eot}"
    ]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
